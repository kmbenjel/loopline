<% content_for :title, "Sign in" %>

<div class="card form-narrow" style="margin: 0 auto;">
  <h1 style="margin-top:0;">Sign in</h1>

  <%= form_with url: session_path do |form| %>
    <div class="form-field">
      <%= form.label :email_address, "Email" %>
      <%= form.email_field :email_address, required: true, autofocus: true, autocomplete: "username", value: params[:email_address] %>
    </div>
    <div class="form-field">
      <%= form.label :password %>
      <%= form.password_field :password, required: true, autocomplete: "current-password", maxlength: 72 %>
    </div>
    <div class="form-actions">
      <%= form.submit "Sign in", class: "btn btn-primary" %>
      <%= link_to "Forgot password?", new_password_path, class: "muted" %>
    </div>
  <% end %>

  <p class="muted" style="margin-bottom:0;">No account? <%= link_to "Sign up", new_registration_path %></p>
</div>
